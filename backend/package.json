    "backup": "ts-node src/scripts/backup-firestore.ts",
    "build": "tsc",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@kloqo/shared": "*",
    "@kloqo/shared-core": "*",
    "@types/jsonwebtoken": "^9.0.10",
    "cors": "^2.8.5",
    "date-fns": "^3.6.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "firebase-admin": "^11.11.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "node-cache": "^5.1.2",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "razorpay": "^2.9.6",
    "resend": "^6.9.4",
    "uuid": "^11.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.8.2",
    "@types/qrcode": "^1.5.6",
    "@types/uuid": "^10.0.0",
    "nodemon": "^3.0.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  }
