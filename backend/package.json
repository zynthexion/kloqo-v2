{
  "name": "kloqo-v2-backend",
  "version": "1.0.0",
  "description": "Kloqo V2 Backend following Clean Architecture",
  "main": "dist/index.js",
  "scripts": {
    "start": "ts-node --transpile-only src/infrastructure/webserver/express/index.ts",
    "dev": "nodemon src/infrastructure/webserver/express/index.ts",
